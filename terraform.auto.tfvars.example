proxmox_endpoint     = "https://pve.example.com:8006/"
proxmox_insecure     = true
default_node_name    = "pve01"
default_datastore_id = "local-lvm"

# Ne placez pas le secret ici. Utilisez :
# $env:TF_VAR_proxmox_api_token = "terraform@pve!terraform=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

templates = {
  template-debian = {
    vm_id     = 9000
    node_name = "pve01"
  }

  template-ubuntu = {
    vm_id     = 9001
    node_name = "pve01"
  }

  template-rocky = {
    vm_id        = 9002
    node_name    = "pve02"
    full_clone   = true
    datastore_id = "ceph-vm"
  }
}

virtual_machines = {
  debian-web-01 = {
    name     = "debian-web-01"
    vm_id    = 1101
    template = "template-debian"
    tags     = ["terraform", "debian", "web"]

    cpu = {
      cores   = 4
      sockets = 1
      type    = "host"
    }

    memory = {
      dedicated = 4096
      floating  = 4096
    }

    disks = {
      scsi0 = {
        size          = 40
        datastore_id  = "local-lvm"
        discard       = "on"
        iothread      = true
        ssd           = true
      }
      scsi1 = {
        size         = 100
        datastore_id = "local-lvm"
        backup       = true
      }
    }

    networks = [
      {
        bridge   = "vmbr0"
        vlan_id  = 120
        firewall = true
        ipv4 = {
          address = "192.168.120.21/24"
          gateway = "192.168.120.1"
        }
      },
      {
        bridge  = "vmbr1"
        vlan_id = 220
        ipv4 = {
          address = "10.220.0.21/24"
        }
      }
    ]

    cloud_init = {
      username    = "debian"
      ssh_keys    = ["ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA... admin@example"]
      dns_domain  = "example.internal"
      dns_servers = ["192.168.120.10", "192.168.120.11"]
    }
  }

  ubuntu-worker-01 = {
    name     = "ubuntu-worker-01"
    template = "template-ubuntu"

    networks = [
      {
        bridge  = "vmbr0"
        vlan_id = 130
        ipv4 = {
          address = "dhcp"
        }
        ipv6 = {
          address = "auto"
        }
      }
    ]

    cloud_init = {
      username = "ubuntu"
      ssh_keys = ["ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA... admin@example"]
    }
  }
}
